# --- Core ---
TZ=Europe/Berlin

# --- StepCA ---
STEPCA_INIT_NAME=home-arpa-ca
STEPCA_INIT_DNS_NAMES=stepca,stepca.app.home.arpa
STEPCA_INIT_ADDRESS=:9000
STEPCA_INIT_PROVISIONER_NAME=admin
STEPCA_INIT_ACME=true

# --- Network / DNS ---
SERVER_LOCAL_IP=192.168.0.10
PIHOLE_DNSMASQ_LISTENING=all
PIHOLE_DNS_UPSTREAMS=unbound#5335
PIHOLE_RATE_LIMIT=150/60

# --- Authelia ---
# Generate with: openssl rand -hex 32
AUTHELIA_SESSION_SECRET=change-me-generate-with-openssl-rand-hex-32
AUTHELIA_STORAGE_ENCRYPTION_KEY=change-me-generate-with-openssl-rand-hex-32
AUTHELIA_JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

