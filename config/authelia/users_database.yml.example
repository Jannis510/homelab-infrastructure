---
users:
  admin:
    displayname: "Admin"
    # Generate password hash:
    # docker run --rm authelia/authelia:4.38.17 authelia crypto hash generate argon2 --password 'your-password'
    password: "$argon2id$v=19$m=65536,t=3,p=4$REPLACE_WITH_REAL_HASH"
    email: admin@home.arpa
    groups:
      - admins